# ═══════════════════════════════════════════════
# ENGAUGE — Environment Configuration
# Copy this to .env and customize for your setup
# ═══════════════════════════════════════════════

# Runtime environment: "local" or "aws"
ENGAUGE_ENV=local

# ── AWS Settings (only used when ENGAUGE_ENV=aws) ──
AWS_REGION=us-east-1
S3_MEDIA_BUCKET=engauge-media
S3_FRONTEND_BUCKET=engauge-frontend
DYNAMODB_ANALYSIS_TABLE=engauge_analysis_results
DYNAMODB_CONTENT_TABLE=engauge_contents
DYNAMODB_TRENDS_TABLE=engauge_trending_topics
DYNAMODB_USERS_TABLE=engauge_users
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_MAX_TOKENS=2048
CLOUDFRONT_DOMAIN=
API_GATEWAY_URL=

# ── Local Settings (only used when ENGAUGE_ENV=local) ──
SQLITE_URL=sqlite:///./engauge.db
LOCAL_MEDIA_DIR=media

# ── CORS ──
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Feature Flags ──
# Set to "true" to use Bedrock LLM instead of heuristics
# Requires valid AWS credentials even in local mode
USE_LLM=false

# ── Optional API Keys (for trend ingestion) ──
NEWS_API_KEY=
